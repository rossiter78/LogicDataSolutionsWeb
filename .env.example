# Cal.com event link for the themed inline scheduler on /contact, e.g.
# "trent-rossiter/discovery-call". Cal.com pulls availability from Trent's
# connected Google Calendar. Real value goes in .env.local (never committed).
NEXT_PUBLIC_CAL_LINK=

# Cloudflare Web Analytics token (set in Cloudflare Pages env at deploy).
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
